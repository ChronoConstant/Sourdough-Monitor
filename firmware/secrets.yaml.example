# ============================================================================
# secrets.yaml.example — configuration template
#
# Copy this file to "secrets.yaml" in the same directory, then fill in your
# own values:
#
#     cp secrets.yaml.example secrets.yaml
#
# secrets.yaml is listed in .gitignore and never gets committed — only this
# .example template does. ESPHome reads secrets.yaml at compile time and bakes
# the values into the firmware.
# ============================================================================

# --- Wi-Fi (required) -------------------------------------------------------
# The ESP32-C3 only supports 2.4 GHz Wi-Fi — it cannot see a 5 GHz network.
# The SSID is case-sensitive; copy it exactly as it appears on your devices.
wifi_ssid: "YourWiFiName"
wifi_password: "YourWiFiPassword"

# --- MQTT broker (required) -------------------------------------------------
# IP address or hostname of your MQTT broker. For most Home Assistant setups
# this is the Mosquitto add-on, and the broker address is your HA machine's
# IP. Enter the address ONLY — no ":1883" port suffix (port is set in
# sourdough.yaml if you need to change it from the default 1883).
mqtt_broker: "192.168.1.10"

# MQTT credentials.
#   - If your broker requires authentication (the HA Mosquitto add-on does
#     by default — create a dedicated Home Assistant user for the device),
#     put that user's name and password here.
#   - If your broker allows anonymous connections, set both to "" (empty).
mqtt_username: "sourdough-monitor"
mqtt_password: "a-password-for-that-user"

# --- OTA update password (required) -----------------------------------------
# Any string you choose. Required for over-the-air firmware updates after the
# first USB flash. You'll be asked for it on each OTA, so keep it somewhere.
ota_password: "choose-something-and-remember-it"

# --- Static IP (OPTIONAL — only if you enable manual_ip in sourdough.yaml) ---
# Leaving the manual_ip block commented out (the default) makes the device
# use DHCP, which works on any network with no configuration. A static IP
# saves ~1-2 s of DHCP negotiation per deep-sleep wake, modestly extending
# battery life. If you enable manual_ip in sourdough.yaml, uncomment these
# four lines and set them for YOUR network:
#   - static_ip: an address OUTSIDE your router's DHCP pool (check the
#     router's DHCP range), or one you've reserved by the device's MAC.
#   - gateway:   your router's IP.
#   - subnet:    almost always 255.255.255.0.
#   - dns1:      usually your router's IP.
#
# static_ip: "192.168.1.246"
# gateway: "192.168.1.1"
# subnet: "255.255.255.0"
# dns1: "192.168.1.1"
